# IAlestra Control Hub — frontend environment
# Copy to .env.local and adjust. Vite only exposes vars prefixed VITE_.
# Restart `npm run dev` after any change here — env is read at startup.

# ── Mock vs. live backend ─────────────────────────────────────────────────────
# true  → fully in-memory mock backend. No backend needed; everything works.
# false → every request hits the real backend at VITE_API_BASE_URL.
VITE_USE_MOCK=false

# ── Backend base URL ──────────────────────────────────────────────────────────
# The origin of the FastAPI backend. The frontend appends /api/v1/... for you.
# Trailing slash is fine — the client strips it automatically.
VITE_API_BASE_URL=https://ialestra-controlhub-fastapi-qa.delightfulhill-3790174e.eastus.azurecontainerapps.io/

# ── Local dev proxy (optional) ────────────────────────────────────────────────
# Only used when VITE_API_BASE_URL is empty. The Vite dev server proxies
# /api/* to this target to avoid CORS errors in local development.
# No trailing slash here — Vite proxy target must be a bare origin.
VITE_API_TARGET=https://ialestra-controlhub-fastapi-qa.delightfulhill-3790174e.eastus.azurecontainerapps.io
