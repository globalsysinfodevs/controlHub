# IAlestra Control Hub — frontend environment
# Copy to .env (or .env.local) and adjust. Vite only exposes vars prefixed VITE_.
# Restart `npm run dev` after any change here — env is read at startup.

# ── Mock vs. live backend ─────────────────────────────────────────────────────
# true  → fully in-memory mock backend. No backend needed; everything works.
# false → hybrid: DEPLOYED routes (auth super-admin + notifications) hit the real
#         backend below; routes not yet deployed (dashboard, agents, chat, users…)
#         keep using the mock so the whole console stays usable.
VITE_USE_MOCK=false

# ── Deployed backend base URL (used when VITE_USE_MOCK=false) ──────────────────
# Just the origin — the frontend appends /api/v1/... for you.
VITE_API_BASE_URL=https://ialestra-controlhub-fastapi-qa.delightfulhill-3790174e.eastus.azurecontainerapps.io

# ── Local dev only (optional) ─────────────────────────────────────────────────
# If VITE_API_BASE_URL is EMPTY, requests go to a relative /api/v1 path and the
# Vite dev server proxies them to this target. Ignored once VITE_API_BASE_URL is
# set, and ignored in production builds (no dev proxy exists there).
VITE_API_TARGET=http://localhost:8000

# NOTE ON CORS: the deployed backend currently allows the origins
# http://localhost:5173 and http://localhost:3000. Run the frontend on port 5173
# (if Vite falls back to 5174 because 5173 is taken, the browser will block the
# call). To use another origin, have the backend add it to CORS_ORIGINS.
