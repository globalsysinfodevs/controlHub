{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{png,jpg,jpeg,gif,svg,ico,css,js,woff,woff2,ttf,eot}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-store"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
